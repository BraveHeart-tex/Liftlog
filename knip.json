    "src/features/workouts/repository.ts": ["exports"],
    "src/lib/utils/set.ts": ["exports"],
    "modules/expo-step-counter/build/**": ["duplicates"],
    "modules/expo-step-counter/src/index.ts": ["duplicates"],
    "src/lib/utils/workout.ts": ["exports"]

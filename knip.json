    "src/components/ui/card.tsx": ["exports"],
    "src/components/ui/snackbar.tsx": ["exports"],
    "src/features/exercises/hooks/index.ts": ["exports", "types"],
    "src/features/exercises/hooks/use-exercise-detail.ts": ["types"],
    "src/features/exercises/repository.ts": ["exports", "types"],
    "src/features/progress/tracking.ts": ["exports"],
    "src/features/workouts/components/progression-suggestion-utils.ts": [
